{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "src/interpretation/corpus/**/*.txt"
    }
  },
  "rewrites": [
    {
      "source": "/favicon.png",
      "destination": "/public/favicon.png"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
